<!DOCTYPE html>
<html>
<head>

    <title>Bootstrap College Website</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-4">

    <h1 class="text-center text-primary">
        ABC College
    </h1>

    <p class="text-center">
        Welcome to ABC College Official Website
    </p>

    <div class="row mt-4">

        <div class="col-md-4 bg-primary text-white p-3">

            <h3>Computer Engineering</h3>

            <p>
                Learn programming, web development,
                database management, and networking.
            </p>

        </div>

        <div class="col-md-4 bg-success text-white p-3">

            <h3>Information Technology</h3>

            <p>
                Study software development,
                cybersecurity, and cloud computing.
            </p>

        </div>

        <div class="col-md-4 bg-danger text-white p-3">

            <h3>Electronics Engineering</h3>

            <p>
                Learn circuits, communication systems,
                and embedded technology.
            </p>

        </div>

    </div>

    <div class="mt-4">

        <h2>About College</h2>

        <p>
            ABC College provides quality education
            with modern laboratories, experienced teachers,
            and placement opportunities for students.
        </p>

    </div>

    <div class="mt-4">

        <h2>Facilities</h2>

        <ul class="list-group">

            <li class="list-group-item">
                Computer Lab
            </li>

            <li class="list-group-item">
                Digital Library
            </li>

            <li class="list-group-item">
                Sports Ground
            </li>

            <li class="list-group-item">
                Wi-Fi Campus
            </li>

        </ul>

    </div>

</div>

